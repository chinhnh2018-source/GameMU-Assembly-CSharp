<!DOCTYPE html>
<html lang="vi" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quan ly su kien GameMU</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background:#0f1115; }
        .navbar-brand { font-weight:700; letter-spacing:.5px; }
        .cat-card { transition: transform .1s; }
        .cat-card:hover { transform: translateY(-2px); }
        .table td, .table th { vertical-align: middle; }
        code { color:#7bd88f; }
        .attr-help { font-size:.75rem; color:#8a93a2; }
        .sticky-actions { position: sticky; top: 0; z-index: 5; }

        /* ===== Bố cục có sidebar bên phải ===== */
        .app-shell { display:flex; flex-direction:column; gap:1.25rem; }
        @@media (min-width: 992px) {
            .app-shell { flex-direction:row; align-items:flex-start; }
            .app-main { flex:1 1 auto; min-width:0; order:1; }
            .app-sidebar {
                flex:0 0 300px; width:300px; order:2;
                position:sticky; top:1rem; max-height:calc(100vh - 2rem); overflow-y:auto;
            }
        }

        /* ===== Sidebar: liệt kê CHỨC NĂNG LỚN ===== */
        .nav-head {
            font-size:.7rem; text-transform:uppercase; letter-spacing:.08em;
            color:#6b7585; margin:.25rem .25rem .6rem;
        }
        .fn-item {
            display:flex; gap:.75rem; align-items:flex-start;
            padding:.7rem .8rem; margin-bottom:.5rem;
            background:#151a21; border:1px solid #262c35; border-radius:.7rem;
            color:#cdd3da; text-decoration:none; transition:all .12s;
        }
        .fn-item:hover { background:#1b212b; border-color:#3a4250; transform:translateY(-1px); color:#fff; }
        .fn-item.active { background:#23211a; border-color:#ffc107; box-shadow:0 0 0 1px #ffc10733 inset; }
        .fn-ic {
            flex:0 0 38px; width:38px; height:38px; border-radius:.55rem;
            display:flex; align-items:center; justify-content:center;
            background:#0f141b; border:1px solid #2a313c; font-size:1.1rem; color:#9aa4b2;
        }
        .fn-item.active .fn-ic { color:#ffc107; border-color:#ffc10755; background:#1a160c; }
        .fn-body { min-width:0; }
        .fn-name { font-weight:600; font-size:.9rem; line-height:1.15; }
        .fn-desc { font-size:.74rem; color:#8a93a2; margin-top:.15rem; }
        .fn-item.active .fn-name { color:#ffc107; }
    </style>
</head>
<body>
@{
    var curPage = (ViewContext.RouteData.Values["page"] as string) ?? "";
    var curKey = ViewContext.RouteData.Values["key"] as string;
    var qModule = Context.Request.Query["module"].ToString();

    // Xác định chức năng lớn đang mở để highlight
    string activeId;
    if (!string.IsNullOrEmpty(qModule))
    {
        activeId = qModule;
    }
    else if (curPage == "/Index")
    {
        activeId = "overview";
    }
    else if (curPage == "/Calendar") { activeId = "calendar"; }
    else if (curPage == "/Features") { activeId = "features"; }
    else if (curPage == "/Links") { activeId = "links"; }
    else if (curPage == "/Backups") { activeId = "backups"; }
    else if (!string.IsNullOrEmpty(curKey))
    {
        var def = EventRegistry.Get(curKey);
        activeId = def != null ? (ModuleRegistry.ForCategory(def.Category)?.Id ?? "") : "";
    }
    else { activeId = ""; }
}
<nav class="navbar navbar-expand-lg bg-dark border-bottom border-secondary mb-3">
    <div class="container-fluid">
        <a class="navbar-brand text-warning" asp-page="/Index"><i class="bi bi-calendar-event"></i> GameMU Event Manager</a>
        <span class="ms-auto text-secondary small d-none d-md-inline">Mọi thay đổi đều tự động sao lưu</span>
    </div>
</nav>

<div class="container-fluid px-3 px-lg-4">
    <div class="app-shell">
        <!-- NỘI DUNG CHÍNH -->
        <main class="app-main">
            @if (TempData["msg"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle"></i> @TempData["msg"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["err"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @TempData["err"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()

            <footer class="mt-5 mb-3 text-secondary small">
                <hr class="border-secondary" />
                Quản lý sự kiện đọc từ <code>GameRes/Config</code> &mdash; mọi thay đổi đều được sao lưu tự động.
            </footer>
        </main>

        <!-- SIDEBAR BÊN PHẢI: CÁC CHỨC NĂNG LỚN -->
        <aside class="app-sidebar">
            <div class="nav-head">Chức năng</div>
            @foreach (var mod in ModuleRegistry.Modules)
            {
                var isActive = mod.Id == activeId;
                var href = mod.IsContent ? "/Index" : (mod.Page ?? "/Index");
                if (mod.IsContent)
                {
                    <a class="fn-item @(isActive ? "active" : "")" asp-page="/Index" asp-route-module="@mod.Id">
                        <span class="fn-ic"><i class="bi bi-@mod.Icon"></i></span>
                        <span class="fn-body">
                            <span class="fn-name">@mod.Name</span>
                            <span class="fn-desc">@mod.Description</span>
                        </span>
                    </a>
                }
                else
                {
                    <a class="fn-item @(isActive ? "active" : "")" asp-page="@mod.Page">
                        <span class="fn-ic"><i class="bi bi-@mod.Icon"></i></span>
                        <span class="fn-body">
                            <span class="fn-name">@mod.Name</span>
                            <span class="fn-desc">@mod.Description</span>
                        </span>
                    </a>
                }
            }
        </aside>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
