<!DOCTYPE html>
<html lang="vi" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quan ly su kien GameMU</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background:#0f1115; }
        .navbar-brand { font-weight:700; letter-spacing:.5px; }
        .cat-card { transition: transform .1s; }
        .cat-card:hover { transform: translateY(-2px); }
        .table td, .table th { vertical-align: middle; }
        code { color:#7bd88f; }
        .attr-help { font-size:.75rem; color:#8a93a2; }
        .sticky-actions { position: sticky; top: 0; z-index: 5; }

        /* ===== Sidebar bên phải ===== */
        .app-shell { display:flex; flex-direction:column; gap:1rem; }
        @@media (min-width: 992px) {
            .app-shell { flex-direction:row; align-items:flex-start; }
            .app-main { flex:1 1 auto; min-width:0; order:1; }
            .app-sidebar {
                flex:0 0 290px; width:290px; order:2;
                position:sticky; top:1rem; max-height:calc(100vh - 2rem); overflow-y:auto;
            }
        }
        .app-sidebar .side-card { background:#151a21; border:1px solid #2a2f37; border-radius:.6rem; }
        .app-sidebar .side-head {
            font-size:.7rem; text-transform:uppercase; letter-spacing:.06em;
            color:#8a93a2; padding:.5rem .85rem .25rem;
        }
        .app-sidebar a.side-link {
            display:flex; align-items:center; gap:.5rem; padding:.4rem .85rem;
            color:#cdd3da; text-decoration:none; font-size:.88rem; border-left:3px solid transparent;
        }
        .app-sidebar a.side-link:hover { background:#1c222b; color:#fff; }
        .app-sidebar a.side-link.active { background:#1f2630; color:#ffc107; border-left-color:#ffc107; }
        .app-sidebar details { border-top:1px solid #21262d; }
        .app-sidebar details > summary {
            list-style:none; cursor:pointer; padding:.45rem .85rem;
            font-size:.82rem; font-weight:600; color:#9aa4b2; display:flex; align-items:center; gap:.4rem;
        }
        .app-sidebar details > summary::-webkit-details-marker { display:none; }
        .app-sidebar details > summary .chev { transition:transform .15s; margin-left:auto; font-size:.7rem; }
        .app-sidebar details[open] > summary .chev { transform:rotate(90deg); }
        .app-sidebar details a.side-link { padding-left:1.6rem; font-size:.82rem; }
        .app-sidebar .badge-count { font-size:.62rem; }
    </style>
</head>
<body>
@{
    var curPage = (ViewContext.RouteData.Values["page"] as string) ?? "";
    var curKey = ViewContext.RouteData.Values["key"] as string;
}
<nav class="navbar navbar-expand-lg bg-dark border-bottom border-secondary mb-3">
    <div class="container-fluid">
        <a class="navbar-brand text-warning" asp-page="/Index"><i class="bi bi-calendar-event"></i> GameMU Event Manager</a>
        <span class="ms-auto text-secondary small d-none d-md-inline">Mọi thay đổi đều tự động sao lưu</span>
    </div>
</nav>

<div class="container-fluid px-3 px-lg-4">
    <div class="app-shell">
        <!-- NỘI DUNG CHÍNH -->
        <main class="app-main">
            @if (TempData["msg"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle"></i> @TempData["msg"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["err"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> @TempData["err"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()

            <footer class="mt-5 mb-3 text-secondary small">
                <hr class="border-secondary" />
                Quản lý sự kiện đọc từ <code>GameRes/Config</code> &mdash; mọi thay đổi đều được sao lưu tự động.
            </footer>
        </main>

        <!-- SIDEBAR BÊN PHẢI: GOM MỌI CHỨC NĂNG -->
        <aside class="app-sidebar">
            <div class="side-card mb-3">
                <div class="side-head">Trang chính</div>
                <a class="side-link @(curPage == "/Index" ? "active" : "")" asp-page="/Index"><i class="bi bi-grid"></i> Trang chủ</a>
                <a class="side-link @(curPage == "/Calendar" ? "active" : "")" asp-page="/Calendar"><i class="bi bi-calendar-range"></i> Lịch sự kiện</a>
                <a class="side-link @(curPage == "/Features" ? "active" : "")" asp-page="/Features"><i class="bi bi-diagram-3"></i> Bản đồ tính năng → XML</a>
                <a class="side-link @(curPage == "/Backups" ? "active" : "")" asp-page="/Backups"><i class="bi bi-clock-history"></i> Sao lưu</a>
            </div>

            <div class="side-card">
                <div class="side-head">Nhóm cấu hình &amp; sự kiện</div>
                @foreach (var grp in EventRegistry.ByCategory())
                {
                    var hasActive = grp.Any(d => d.Key == curKey);
                    <details @(hasActive ? "open" : "")>
                        <summary>
                            <i class="bi bi-folder2"></i> @grp.Key
                            <span class="badge bg-secondary badge-count">@grp.Count()</span>
                            <i class="bi bi-chevron-right chev"></i>
                        </summary>
                        @foreach (var def in grp)
                        {
                            <a class="side-link @(def.Key == curKey ? "active" : "")"
                               asp-page="/File" asp-route-key="@def.Key" title="@def.DisplayName">
                                <i class="bi bi-dot"></i>
                                <span class="text-truncate">@def.DisplayName</span>
                            </a>
                        }
                    </details>
                }
            </div>
        </aside>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
