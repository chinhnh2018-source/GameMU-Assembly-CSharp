<!DOCTYPE html>
<html lang="vi" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quan ly su kien GameMU</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body { background:#0f1115; }
        .navbar-brand { font-weight:700; letter-spacing:.5px; }
        .cat-card { transition: transform .1s; }
        .cat-card:hover { transform: translateY(-2px); }
        .table td, .table th { vertical-align: middle; }
        code { color:#7bd88f; }
        .attr-help { font-size:.75rem; color:#8a93a2; }
        .sticky-actions { position: sticky; top: 0; z-index: 5; }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg bg-dark border-bottom border-secondary mb-4">
    <div class="container-fluid">
        <a class="navbar-brand text-warning" asp-page="/Index"><i class="bi bi-calendar-event"></i> GameMU Event Manager</a>
        <div class="ms-auto d-flex gap-2">
            <a class="btn btn-sm btn-outline-light" asp-page="/Index"><i class="bi bi-grid"></i> Trang chủ</a>
            <a class="btn btn-sm btn-outline-warning" asp-page="/Calendar"><i class="bi bi-calendar-range"></i> Lịch sự kiện</a>
            <a class="btn btn-sm btn-outline-info" asp-page="/Features"><i class="bi bi-diagram-3"></i> Bản đồ tính năng → XML</a>
            <a class="btn btn-sm btn-outline-secondary" asp-page="/Backups"><i class="bi bi-clock-history"></i> Sao lưu</a>
        </div>
    </div>
</nav>
<main class="container-fluid px-3 px-lg-4">
    @if (TempData["msg"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> @TempData["msg"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["err"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> @TempData["err"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @RenderBody()
</main>
<footer class="container-fluid px-3 px-lg-4 mt-5 mb-3 text-secondary small">
    <hr class="border-secondary" />
    Quản lý sự kiện đọc từ <code>GameRes/Config</code> &mdash; mọi thay đổi đều được sao lưu tự động.
</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
