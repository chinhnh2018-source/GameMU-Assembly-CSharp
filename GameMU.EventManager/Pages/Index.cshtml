@page
@model IndexModel
@{
    ViewData["Title"] = "Trang chủ";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h3 class="mb-0"><i class="bi bi-calendar-event text-warning"></i> Quản lý sự kiện</h3>
    <span class="text-secondary small">Nguồn: <code>@Model.ConfigRoot</code></span>
</div>

@if (!Model.RootExists)
{
    <div class="alert alert-warning">
        <b>Không tìm thấy thư mục cấu hình.</b> Hãy sửa <code>EventManager:GameResConfigPath</code> trong <code>appsettings.json</code>
        trỏ tới <code>GameRes/GameRes/Config</code> của GameServer. Hiện tại: <code>@Model.ConfigRoot</code>
    </div>
}
else
{
    @foreach (var grp in EventRegistry.ByCategory())
    {
        <h5 class="mt-4 mb-2 text-info border-bottom border-secondary pb-1">@grp.Key</h5>
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xxl-4 g-3">
            @foreach (var def in grp)
            {
                var ok = Model.Exists.GetValueOrDefault(def.Key);
                <div class="col">
                    <div class="card cat-card h-100 bg-dark border-secondary">
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title mb-1">@def.DisplayName</h6>
                            <div class="small text-secondary mb-2 flex-grow-1">@def.Description</div>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    @if (ok)
                                    {
                                        <span class="badge bg-secondary">@Model.Counts.GetValueOrDefault(def.Key) mục</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">thiếu file</span>
                                    }
                                    <span class="badge bg-info-subtle text-info border border-info">@ToggleLabel(def.Toggle)</span>
                                </div>
                                <a class="btn btn-sm btn-warning @(ok ? "" : "disabled")"
                                   asp-page="/File" asp-route-key="@def.Key">Mở <i class="bi bi-arrow-right"></i></a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@functions {
    static string ToggleLabel(GameMU.EventManager.Models.ToggleStrategy t) => t switch
    {
        GameMU.EventManager.Models.ToggleStrategy.Flag => "Bật/tắt: cờ",
        GameMU.EventManager.Models.ToggleStrategy.DateWindow => "Bật/tắt: khung ngày",
        GameMU.EventManager.Models.ToggleStrategy.Park => "Bật/tắt: gỡ tạm",
        _ => "Chỉ sửa"
    };
}
