@page
@model IndexModel
@{
    var selected = ModuleRegistry.Get(Model.Module);
    ViewData["Title"] = selected?.Name ?? "Tổng quan";
    var contentModules = ModuleRegistry.Modules.Where(m => m.IsContent).ToList();
    var shown = selected != null && selected.IsContent ? new[] { selected }.ToList() : contentModules;
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h3 class="mb-0">
        <i class="bi bi-@(selected?.Icon ?? "speedometer2") text-warning"></i>
        @(selected?.Name ?? "Tổng quan")
    </h3>
    <span class="text-secondary small">Nguồn: <code>@Model.ConfigRoot</code></span>
</div>

@if (!Model.RootExists)
{
    <div class="alert alert-warning">
        <b>Không tìm thấy thư mục cấu hình.</b> Hãy sửa <code>EventManager:GameResConfigPath</code> trong
        <code>appsettings.json</code> trỏ tới <code>GameRes/GameRes/Config</code>. Hiện tại: <code>@Model.ConfigRoot</code>
    </div>
}
else
{
    @if (selected != null && selected.IsContent)
    {
        <p class="text-secondary mb-3">@selected.Description &mdash;
            <a asp-page="/Index" class="link-info text-decoration-none"><i class="bi bi-arrow-left"></i> xem tất cả chức năng</a>
        </p>
    }

    @foreach (var mod in shown)
    {
        @if (selected == null || !selected.IsContent)
        {
            <div class="d-flex align-items-center gap-2 mt-4 mb-2">
                <i class="bi bi-@mod.Icon text-warning fs-5"></i>
                <h4 class="mb-0">@mod.Name</h4>
                <a class="btn btn-sm btn-outline-secondary ms-2" asp-page="/Index" asp-route-module="@mod.Id">
                    Mở riêng <i class="bi bi-box-arrow-up-right"></i>
                </a>
            </div>
            <div class="text-secondary small mb-2">@mod.Description</div>
        }

        @foreach (var cat in mod.Categories)
        {
            var defs = EventRegistry.Files.Where(d => d.Category == cat).ToList();
            if (!defs.Any()) { continue; }
            <h6 class="mt-3 mb-2 text-info border-bottom border-secondary pb-1">@cat</h6>
            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xxl-4 g-3">
                @foreach (var def in defs)
                {
                    var ok = Model.Exists.GetValueOrDefault(def.Key);
                    <div class="col">
                        <div class="card cat-card h-100 bg-dark border-secondary">
                            <div class="card-body d-flex flex-column">
                                <h6 class="card-title mb-1">@def.DisplayName</h6>
                                <div class="small text-secondary mb-2 flex-grow-1">@def.Description</div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        @if (ok)
                                        {
                                            <span class="badge bg-secondary">@Model.Counts.GetValueOrDefault(def.Key) mục</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">thiếu file</span>
                                        }
                                        <span class="badge bg-info-subtle text-info border border-info">@ToggleLabel(def.Toggle)</span>
                                    </div>
                                    <a class="btn btn-sm btn-warning @(ok ? "" : "disabled")"
                                       asp-page="/File" asp-route-key="@def.Key">Mở <i class="bi bi-arrow-right"></i></a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
}

@functions {
    static string ToggleLabel(GameMU.EventManager.Models.ToggleStrategy t) => t switch
    {
        GameMU.EventManager.Models.ToggleStrategy.Flag => "Bật/tắt: cờ",
        GameMU.EventManager.Models.ToggleStrategy.DateWindow => "Bật/tắt: khung ngày",
        GameMU.EventManager.Models.ToggleStrategy.Park => "Bật/tắt: gỡ tạm",
        _ => "Chỉ sửa"
    };
}
