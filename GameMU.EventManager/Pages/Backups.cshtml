@page
@model BackupsModel
@{ ViewData["Title"] = "Sao luu"; }

<h4><i class="bi bi-clock-history"></i> Sao luu gan day</h4>
<p class="small text-secondary">Luu tai: <code>@Model.Root/_EventManager/backups/</code> (hien 50 ban moi nhat). Muon khoi phuc, chep file <code>.bak</code> de len file goc.</p>

<div class="table-responsive">
    <table class="table table-dark table-sm table-striped">
        <thead><tr><th>#</th><th>Ten file sao luu</th></tr></thead>
        <tbody>
        @for (int i = 0; i < Model.Backups.Count; i++)
        {
            <tr><td>@(i+1)</td><td><code>@Model.Backups[i]</code></td></tr>
        }
        @if (Model.Backups.Count == 0)
        {
            <tr><td colspan="2" class="text-center text-secondary py-3">Chua co ban sao luu nao.</td></tr>
        }
        </tbody>
    </table>
</div>
