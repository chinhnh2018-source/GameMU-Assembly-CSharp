@page
@model BackupsModel
@{ ViewData["Title"] = "Sao lưu"; }

<h4><i class="bi bi-clock-history"></i> Sao lưu gần đây</h4>
<p class="small text-secondary">Lưu tại: <code>@Model.Root/_EventManager/backups/</code> (hiện 50 bản mới nhất). Muốn khôi phục, chép file <code>.bak</code> đè lên file gốc.</p>

<div class="table-responsive">
    <table class="table table-dark table-sm table-striped">
        <thead><tr><th>#</th><th>Tên file sao lưu</th></tr></thead>
        <tbody>
        @for (int i = 0; i < Model.Backups.Count; i++)
        {
            <tr><td>@(i+1)</td><td><code>@Model.Backups[i]</code></td></tr>
        }
        @if (Model.Backups.Count == 0)
        {
            <tr><td colspan="2" class="text-center text-secondary py-3">Chưa có bản sao lưu nào.</td></tr>
        }
        </tbody>
    </table>
</div>
