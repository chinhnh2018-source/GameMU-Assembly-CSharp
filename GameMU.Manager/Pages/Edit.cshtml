@page "/edit/{key}/{id?}"
@model EditModel
@{
    var def = Model.Def;
    ViewData["Title"] = (Model.IsNew ? "Thêm mới - " : "Sửa - ") + (def?.DisplayName ?? "");
}

@if (def == null) {
    <p>Không tìm thấy cấu hình.</p>
    return;
}

<h4>@(Model.IsNew ? "Thêm mục mới" : "Chỉnh sửa mục " + Model.Id)</h4>
<p class="text-muted">
    <code>@def.RelativePath</code> · thẻ <code>&lt;@def.ItemElement&gt;</code>
</p>

@if (!string.IsNullOrEmpty(Model.Comment))
{
    <div class="alert alert-secondary py-2">
        <strong>Chú thích gốc:</strong> @Model.Comment
    </div>
}

<form method="post">
    <input type="hidden" asp-for="Key" />
    <input type="hidden" asp-for="Id" />

    @foreach (var f in Model.Fields)
    {
        var val = Model.Values.GetValueOrDefault(f, "");
        var help = Model.Label(f);
        var isId = f == def.IdAttr;
        var isLong = val.Length > 60 || f.StartsWith("Goods") || f.Contains("Time") || f == "List" || f == "Intro" || f == "Value";
        var isFk = Model.FkTargets.ContainsKey(f);
        var fkTarget = isFk ? Model.FkTargets[f] : null;

        <div class="mb-3">
            <label class="form-label fw-semibold">
                @f
                @if (isId) { <span class="badge text-bg-warning ms-1">khóa</span> }
                @if (isFk && fkTarget != null)
                {
                    <a href="/file/@fkTarget" class="badge text-bg-info ms-1 text-decoration-none">liên kết</a>
                }
                else if (isFk)
                {
                    <span class="badge text-bg-secondary ms-1">goods</span>
                }
            </label>
            @if (help != null) {
                <div class="form-text text-muted mb-1">@help</div>
            }
            @if (isLong)
            {
                <textarea name="f_@f" rows="2" class="form-control form-control-sm font-monospace">@val</textarea>
            }
            else
            {
                <input type="text" name="f_@f" value="@val" class="form-control form-control-sm" />
            }
        </div>
    }

    @if (Model.IsNew)
    {
        <div class="mb-3" id="extra-fields">
            <label class="form-label fw-semibold text-muted">
                Thêm thuộc tính tự do (nếu file có thuộc tính chưa liệt kê):
            </label>
            <div id="extra-rows"></div>
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="addExtraField()">+ Thêm ô</button>
        </div>
    }

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Lưu</button>
        <a href="/file/@Key" class="btn btn-outline-secondary">Hủy</a>
    </div>
    <small class="text-muted d-block mt-2">
        File gốc sẽ được sao lưu tự động vào <code>_EventManager/backups/</code> trước khi ghi đè.
        Định dạng (tab/space) và chú thích được giữ nguyên.
    </small>
</form>

@section Scripts {
    <script src="~/js/GoodsDataEditor.js"></script>
    <script>
        function addExtraField() {
            const div = document.getElementById('extra-rows');
            const i = div.children.length;
            div.insertAdjacentHTML('beforeend', `
                <div class="row g-2 mb-1">
                    <div class="col-4">
                        <input type="text" name="f_extra_name_${i}" placeholder="Tên thuộc tính"
                               class="form-control form-control-sm" oninput="syncExtraName(this,'${i}')">
                    </div>
                    <div class="col">
                        <input type="text" id="extra_val_${i}" name="" placeholder="Giá trị"
                               class="form-control form-control-sm">
                    </div>
                </div>`);
        }
        function syncExtraName(el, i) {
            const val = document.getElementById('extra_val_' + i);
            if (val) val.name = el.value ? 'f_' + el.value.trim() : '';
        }
    </script>
}
