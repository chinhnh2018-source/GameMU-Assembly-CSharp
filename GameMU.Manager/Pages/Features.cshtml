@page
@model FeaturesModel
@{
    ViewData["Title"] = "Bản đồ tính năng → XML";
    // map: tên file xml (thường) -> key trong registry (nếu được quản lý) để tạo liên kết
    var managed = EventRegistry.Files
        .GroupBy(f => System.IO.Path.GetFileName(f.RelativePath).ToLowerInvariant())
        .ToDictionary(g => g.Key, g => g.First().Key);
}

<div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-diagram-3 text-info"></i> Bản đồ tính năng → file XML</h4>
    <span class="text-secondary small">@FeatureCatalog.Items.Count tính năng &middot; quét từ mã nguồn GameServer</span>
</div>
<p class="small text-secondary">
    Mỗi dòng là một lớp quản lý (manager) trong GameServer và danh sách file XML trong <code>GameRes/Config</code> mà nó đọc.
    File có gạch chân là file đang được trình quản lý hỗ trợ — bấm để mở.
</p>

<form method="get" class="row g-2 mb-3">
    <div class="col-sm-6 col-md-4">
        <input class="form-control form-control-sm" name="q" value="@Model.Q" placeholder="Tìm tính năng / file XML / manager..." />
    </div>
    <div class="col-auto"><button class="btn btn-sm btn-outline-light">Tìm</button></div>
    <div class="col-auto d-flex align-items-center text-secondary small">@Model.Items.Count kết quả</div>
</form>

@foreach (var grp in Model.Items.GroupBy(i => i.Category).OrderBy(g => g.Key))
{
    <h5 class="mt-4 mb-2 text-info border-bottom border-secondary pb-1">@grp.Key</h5>
    <div class="table-responsive">
        <table class="table table-dark table-striped table-sm align-middle">
            <thead>
                <tr>
                    <th style="width:28%">Tính năng</th>
                    <th style="width:24%">Lớp quản lý (manager)</th>
                    <th>File XML sử dụng</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var it in grp)
            {
                <tr>
                    <td><b>@it.Feature</b></td>
                    <td class="small text-secondary font-monospace">@it.Manager</td>
                    <td>
                        @foreach (var x in it.Xmls)
                        {
                            var lk = x.ToLowerInvariant();
                            if (managed.TryGetValue(lk, out var key))
                            {
                                <a class="badge bg-secondary text-decoration-underline me-1 mb-1" asp-page="/File" asp-route-key="@key">@x</a>
                            }
                            else
                            {
                                <span class="badge bg-dark border border-secondary text-secondary me-1 mb-1">@x</span>
                            }
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@if (Model.Items.Count == 0)
{
    <div class="text-center text-secondary py-4">Không có kết quả.</div>
}
