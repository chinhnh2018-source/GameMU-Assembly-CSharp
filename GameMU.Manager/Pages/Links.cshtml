@page
@model LinksModel
@{
    ViewData["Title"] = "Liên kết XML";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h3 class="mb-0"><i class="bi bi-share text-warning"></i> Liên kết giữa các file XML</h3>
    <span class="text-secondary small">Thể hiện quan hệ "khóa ngoại" giữa các cấu hình &amp; đối soát thực tế</span>
</div>

@if (!Model.RootExists)
{
    <div class="alert alert-warning"><b>Không tìm thấy thư mục cấu hình.</b></div>
}
else
{
    <!-- 1. Sơ đồ quan hệ -->
    <h5 class="mt-2 mb-2 text-info border-bottom border-secondary pb-1">Sơ đồ quan hệ tham chiếu</h5>
    <div class="table-responsive">
        <table class="table table-dark table-sm align-middle">
            <thead>
                <tr class="text-secondary">
                    <th>File nguồn</th><th>Trường</th><th></th><th>File đích</th><th>Khóa</th><th>Ý nghĩa</th><th>Đối soát</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var l in Model.Links)
                {
                    <tr>
                        <td><code>@l.SourceFile</code></td>
                        <td><span class="badge bg-secondary">@l.SourceField</span></td>
                        <td class="text-warning"><i class="bi bi-arrow-right"></i></td>
                        <td><code>@l.TargetFile</code></td>
                        <td><span class="badge bg-info-subtle text-info border border-info">@l.TargetKey</span></td>
                        <td class="small text-secondary">@l.Description</td>
                        <td>
                            @if (l.LiveChecked)
                            {
                                <span class="badge bg-success">Có</span>
                            }
                            else
                            {
                                <span class="badge bg-dark border border-secondary text-secondary">Tài liệu</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- 2. Đối soát GroupID: SpecialActivity ↔ SpecialActivityTime -->
    <h5 class="mt-4 mb-2 text-info border-bottom border-secondary pb-1">
        Đợt hoạt động đặc biệt (gom theo GroupID)
    </h5>
    <p class="text-secondary small">
        Một đợt = nhiều <code>&lt;Activity&gt;</code> cùng <code>GroupID</code> + 1 <code>&lt;Time&gt;</code> cùng GroupID quyết định lịch chạy.
    </p>

    @if (Model.OrphanGroups.Any())
    {
        <div class="alert alert-danger py-2">
            <b><i class="bi bi-exclamation-octagon"></i> @Model.OrphanGroups.Count nhóm thiếu lịch chạy (&lt;Time&gt;):</b>
            <span class="small">@string.Join(", ", Model.OrphanGroups.Take(30))@(Model.OrphanGroups.Count > 30 ? "..." : "")</span>
            <div class="small text-secondary mt-1">Các đợt này có vật phẩm/hoạt động nhưng không có khung thời gian → server sẽ không kích hoạt.</div>
        </div>
    }
    @if (Model.UnusedTimes.Any())
    {
        <div class="alert alert-warning py-2">
            <b><i class="bi bi-exclamation-triangle"></i> @Model.UnusedTimes.Count lịch &lt;Time&gt; mồ côi (không nhóm Activity nào dùng):</b>
            <span class="small">@string.Join(", ", Model.UnusedTimes.Take(30))@(Model.UnusedTimes.Count > 30 ? "..." : "")</span>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-dark table-sm table-hover align-middle">
            <thead>
                <tr class="text-secondary">
                    <th>GroupID</th><th>Tên đợt</th><th class="text-center">Số hoạt động</th><th>Lịch chạy</th><th>Trạng thái nối</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var g in Model.Groups.Take(200))
                {
                    <tr>
                        <td><code>@g.GroupId</code></td>
                        <td>@g.Name</td>
                        <td class="text-center"><span class="badge bg-secondary">@g.ActivityCount</span></td>
                        <td class="small">
                            @if (g.HasTime && (g.From != null || g.To != null))
                            {
                                <span>@(g.From?.ToString("dd/MM/yyyy") ?? "?") &rarr; @(g.To?.ToString("dd/MM/yyyy") ?? "?")</span>
                            }
                            else if (g.HasTime)
                            {
                                <span class="text-secondary">có Time (chưa đặt ngày)</span>
                            }
                            else
                            {
                                <span class="text-danger">— chưa có —</span>
                            }
                        </td>
                        <td>
                            @if (g.HasTime)
                            {
                                <span class="badge bg-success"><i class="bi bi-link-45deg"></i> Đã nối</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Thiếu Time</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (Model.Groups.Count > 200)
    {
        <div class="text-secondary small">Hiển thị 200/@Model.Groups.Count nhóm đầu tiên.</div>
    }

    <!-- 3. Đối soát GoodsID -->
    <h5 class="mt-4 mb-2 text-info border-bottom border-secondary pb-1">Đối soát mã vật phẩm với Goods.xml</h5>
    <div class="row g-3">
        <div class="col-6 col-lg-3">
            <div class="card bg-dark border-secondary"><div class="card-body py-2">
                <div class="text-secondary small">Item trong Goods.xml</div>
                <div class="fs-4">@Model.GoodsTotal</div>
            </div></div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card bg-dark border-secondary"><div class="card-body py-2">
                <div class="text-secondary small">Mã được tham chiếu</div>
                <div class="fs-4">@Model.GoodsRefCount</div>
            </div></div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="card bg-dark border-@(Model.MissingGoods.Any() ? "danger" : "secondary")"><div class="card-body py-2">
                <div class="text-secondary small">Mã KHÔNG tồn tại</div>
                <div class="fs-4 @(Model.MissingGoods.Any() ? "text-danger" : "text-success")">@Model.MissingGoods.Count</div>
            </div></div>
        </div>
    </div>
    @if (Model.MissingGoods.Any())
    {
        <div class="alert alert-danger mt-3 py-2">
            <b><i class="bi bi-x-octagon"></i> Mã vật phẩm thiếu trong Goods.xml:</b>
            <span class="small">@string.Join(", ", Model.MissingGoods.Take(50))@(Model.MissingGoods.Count > 50 ? "..." : "")</span>
        </div>
    }
    else if (Model.GoodsTotal > 0)
    {
        <div class="alert alert-success mt-3 py-2"><i class="bi bi-check-circle"></i> Tất cả mã vật phẩm trong hoạt động đặc biệt đều hợp lệ.</div>
    }
}
